<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>S'mart House | Premium Fashion Store</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

html{
    scroll-behavior:smooth;
}

body{
    background:#050816;
    color:white;
}

/* HEADER */

header{
    width:100%;
    background:#020617;
    padding:15px 5%;
    display:flex;
    justify-content:space-between;
    align-items:center;
    position:fixed;
    top:0;
    z-index:1000;
    border-bottom:2px solid gold;
}

.logo{
    display:flex;
    align-items:center;
    gap:15px;
}

.logo img{
    width:65px;
    height:65px;
    border-radius:50%;
    border:2px solid gold;
}

.logo h1{
    color:gold;
    font-size:28px;
}

nav a{
    text-decoration:none;
    color:white;
    margin-left:25px;
    font-weight:500;
    transition:0.3s;
}

nav a:hover{
    color:gold;
}

/* HERO */

.hero{
    min-height:100vh;
    background:
    linear-gradient(rgba(0,0,0,0.7),rgba(0,0,0,0.7)),
    url('https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1400') center/cover;

    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    padding:20px;
}

.hero-content{
    margin-top:80px;
}

.hero h2{
    font-size:65px;
    color:gold;
}

.hero p{
    margin-top:20px;
    font-size:20px;
    color:#ddd;
}

.hero-btns{
    margin-top:35px;
}

.btn{
    display:inline-block;
    padding:15px 32px;
    border-radius:10px;
    text-decoration:none;
    font-weight:600;
    margin:10px;
    transition:0.3s;
}

.btn-gold{
    background:gold;
    color:black;
}

.btn-dark{
    border:2px solid gold;
    color:gold;
}

.btn:hover{
    transform:translateY(-5px);
}

/* SECTION */

section{
    padding:90px 5%;
}

.section-title{
    text-align:center;
    margin-bottom:60px;
}

.section-title h2{
    font-size:42px;
    color:gold;
}

/* PRODUCTS */

.product-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:30px;
}

.product{
    background:#0f172a;
    border-radius:18px;
    overflow:hidden;
    transition:0.4s;
    border:1px solid #1e293b;
}

.product:hover{
    transform:translateY(-10px);
    border-color:gold;
}

.product img{
    width:100%;
    height:350px;
    object-fit:cover;
}

.product-info{
    padding:25px;
}

.product-info h3{
    margin-bottom:10px;
    font-size:24px;
}

.price{
    color:gold;
    font-size:24px;
    margin-bottom:20px;
}

/* FEATURE */

.features{
    background:#020617;
}

.feature-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:25px;
}

.feature{
    background:#0f172a;
    padding:35px;
    border-radius:18px;
    text-align:center;
    border:1px solid #1e293b;
}

.feature h3{
    color:gold;
    margin-top:15px;
}

/* ABOUT */

.about{
    text-align:center;
}

.about p{
    max-width:900px;
    margin:auto;
    line-height:1.9;
    color:#ccc;
    margin-top:20px;
}

/* CONTACT */

.contact-box{
    max-width:700px;
    margin:auto;
    background:#0f172a;
    padding:40px;
    border-radius:20px;
    border:1px solid gold;
}

.contact-box input,
.contact-box textarea{
    width:100%;
    padding:16px;
    margin-top:18px;
    border:none;
    border-radius:10px;
    background:#1e293b;
    color:white;
    font-size:16px;
}

.contact-box button{
    width:100%;
    margin-top:20px;
    padding:16px;
    background:gold;
    border:none;
    border-radius:10px;
    font-size:18px;
    font-weight:bold;
    cursor:pointer;
}

/* FACEBOOK */

.facebook{
    background:#020617;
    text-align:center;
}

.facebook a{
    display:inline-block;
    margin-top:20px;
    text-decoration:none;
    background:#1877f2;
    padding:15px 35px;
    border-radius:10px;
    color:white;
    font-weight:600;
}

/* FOOTER */

footer{
    background:#000814;
    text-align:center;
    padding:25px;
    border-top:2px solid gold;
}

/* MOBILE */

@media(max-width:768px){

    header{
        flex-direction:column;
        gap:15px;
    }

    nav{
        display:flex;
        flex-wrap:wrap;
        justify-content:center;
    }

    nav a{
        margin:8px;
    }

    .hero h2{
        font-size:40px;
    }

    .hero p{
        font-size:16px;
    }

    .section-title h2{
        font-size:32px;
    }
}

</style>
</head>

